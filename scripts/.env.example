# SophiaCore Attestation Inspector — Environment Configuration
# Copy to .env and fill in values for your deployment.

# ── Ollama Configuration ────────────────────────────────────────────
# Comma-separated list of Ollama host URLs (failover chain, tried in order)
SOPHIA_OLLAMA_HOSTS=http://192.168.0.160:11434,http://100.75.100.89:11434,http://localhost:11434

# Ollama model identifier
SOPHIA_MODEL=elyan-sophia:7b-q4_K_M

# ── Service Configuration ───────────────────────────────────────────
# Port for the Sophia HTTP API server
SOPHIA_PORT=9130

# SQLite database path
SOPHIA_DB_PATH=sophia_inspections.db

# RustChain node URL (for fetching miners and epoch data)
NODE_API_URL=https://50.28.86.131

# ── Authentication ──────────────────────────────────────────────────
# HTTP Basic Auth credentials for the admin dashboard and override endpoint
# Leave empty to disable authentication (trusted network only)
SOPHIA_ADMIN_USER=
SOPHIA_ADMIN_PASS=

# Bearer token for the anomaly trigger endpoint (/sophia/trigger/{miner_id})
# Used by the sybil risk scorer to trigger immediate inspections
SOPHIA_TRIGGER_SECRET=

# ── Scheduler Configuration ─────────────────────────────────────────
# Interval between batch inspections in seconds (default: 86400 = 24h)
# SOPHIA_BATCH_INTERVAL=86400

# Delay between individual miner inspections in seconds
# SOPHIA_INSPECT_DELAY=2.0
